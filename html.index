<!DOCTYPE html>
<html>
<head>
<title>Luxury Food Order</title>
<style>
body{
    background:#0f0f0f;
    color:white;
    font-family:Arial;
    text-align:center;
}

.container{
    display:flex;
    justify-content:center;
    gap:20px;
    margin-top:50px;
}

.card{
    background:#1e1e1e;
    padding:20px;
    border-radius:15px;
    width:200px;
}

button{
    background:gold;
    border:none;
    padding:10px 20px;
    border-radius:10px;
    cursor:pointer;
}
</style>
</head>

<body>

<h1>Luxury Food Order</h1>

<div class="container">

<div class="card">
<h3>Burger</h3>
<p>$12</p>
<button>Order</button>
</div>

<div class="card">
<h3>Pizza</h3>
<p>$15</p>
<button>Order</button>
</div>

<div class="card">
<h3>Pasta</h3>
<p>$10</p>
<button>Order</button>
</div>

</div>

</body>
</html>
